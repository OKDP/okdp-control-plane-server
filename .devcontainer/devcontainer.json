{
  "name": "OKDP Control Plane Server",
  "build": {
    "dockerfile": "Dockerfile"
  },
  // reach the dev-sandbox API on the host via host.docker.internal (--add-host is for Linux)
  "runArgs": ["--add-host=host.docker.internal:host-gateway"],
  // publish 8093 to the host so the front reaches the API (gin binds 0.0.0.0:8093)
  "appPort": ["8093:8093"],
  "portsAttributes": {
    "8093": { "label": "OKDP server" }
  },
  "mounts": [
    // host kubeconfig. The postStart hook derives a container-reachable copy in .dev/
    "source=${localEnv:HOME}/.kube,target=/home/vscode/.kube,type=bind,consistency=cached",
    "source=okdp-server-gomodcache,target=/go/pkg/mod,type=volume",
    "source=okdp-server-gobuildcache,target=/home/vscode/.cache/go-build,type=volume"
  ],
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
  "workspaceFolder": "/workspace",
  // cache volumes mount root-owned, so chown them to vscode before downloading
  "postCreateCommand": "sudo chown -R vscode:vscode /go/pkg/mod /home/vscode/.cache && go mod download",
  // Re-derive the container-reachable kubeconfig on every start (covers cluster recreation).
  "postStartCommand": "bash .devcontainer/sync-kubeconfig.sh",
  // KUBECONFIG points at the synced file, so kubectl, go run, dlv and air all reach the cluster.
  "remoteEnv": { "KUBECONFIG": "${containerWorkspaceFolder}/.dev/kubeconfig" },
  "remoteUser": "vscode",
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "go.useLanguageServer": true,
        "go.toolsManagement.checkForUpdates": "local",
        "go.lintTool": "golangci-lint",
        "go.lintOnSave": "package",
        "[go]": {
          "editor.formatOnSave": true,
          "editor.defaultFormatter": "golang.go"
        }
      }
    }
  }
}
